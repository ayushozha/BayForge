WAITLIST_API_URL=https://emailwaitlist.ayushojha.com/api/v1/subscribe
WAITLIST_STATS_URL=https://emailwaitlist.ayushojha.com/api/v1/stats
# Leave empty for local fallback mode. Set a real key to enable live signup and stats.
WAITLIST_API_KEY=

# Optional fallback/source when the waitlist stats API is unavailable.
# Point this to a server-side uploaded CSV, TXT, TSV, or JSON file containing emails.
COMMUNITY_EMAIL_LIST_PATH=./data/community-emails.csv
