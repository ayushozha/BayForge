WAITLIST_API_URL=https://emailwaitlist.ayushojha.com/api/v1/subscribe
WAITLIST_STATS_URL=https://emailwaitlist.ayushojha.com/api/v1/stats
# Leave empty for local fallback mode. Set a real key to enable live signup and stats.
WAITLIST_API_KEY=

# Optional fallback/source when the waitlist stats API is unavailable.
# Point this to a server-side uploaded CSV, TXT, TSV, or JSON file containing emails.
COMMUNITY_EMAIL_LIST_PATH=./data/community-emails.csv

# Optional backend/database export used for aggregate stats such as events hosted,
# projects built, and colleges represented.
# The file must live under ./data or ./uploads and may be CSV, TSV, or JSON.
COMMUNITY_DATABASE_EXPORT_PATH=./data/community-database-export.csv

# Optional backend/database export for organizer-managed event cards and event-section stats.
# The file must live under ./data or ./uploads and may be CSV, TSV, or JSON.
COMMUNITY_EVENTS_EXPORT_PATH=./data/community-events-export.csv

# Optional backend/database export for dashboard-managed sponsor and partner logos.
# The file must live under ./data or ./uploads and may be CSV, TSV, or JSON.
COMMUNITY_SPONSORS_EXPORT_PATH=./data/community-sponsors-export.csv

# Optional backend/database export for dashboard-managed newsletter section copy.
# The file must live under ./data or ./uploads and may be CSV, TSV, or JSON.
COMMUNITY_NEWSLETTER_EXPORT_PATH=./data/community-newsletter-export.csv

# Resend transactional email. The send-only key works today from
# onboarding@resend.dev; switch EMAIL_FROM to a bayforge.events address once
# the domain is verified at https://resend.com/domains.
RESEND_API_KEY=
EMAIL_FROM=Bay Forge <onboarding@resend.dev>
NOTIFY_EMAIL=outreach@bayforge.events
